flowchart TD

    subgraph S1["① Sensor & Physical Layer — Telemetry Intake + Anti-Spoofing"]
        direction TB
        S1a["Wallet Address Input<br>(0x format validation)"]
        S1b["Ethereum / On-Chain APIs<br>Etherscan · Alchemy · The Graph · Dune"]
        S1b_rpc["🛡️ Multi-Node RPC Consensus<br>Cross-verify state hash across<br>independent nodes — §6.3<br>If hash mismatch → route to Fallback Pipeline"]
        S1b_orch["⚙️ Quapp.cloud Orchestrator<br>Async middleware · Strict timeout limits<br>Fallback redundancy pipeline on timeout — §7"]
        S1c["Directed Transaction Graph G=(V,E)<br>eᵢⱼ = (i, j, Aᵢⱼ, tᵢⱼ, cᵢⱼ)<br>bounded by hop distance H"]
        S1a --> S1b --> S1b_rpc --> S1b_orch --> S1c
    end

    subgraph S2["② Signal Conditioning — Feature Extraction, Noise Filtering & Smurfing Detection"]
        direction TB
        S2a["Raw AML Feature Extraction (11 indicators)<br>amount anomaly, velocity, structuring,<br>rapid flow, geo risk, counterparty risk..."]
        S2b["Robust Normalization → [0,1]<br>φᵏᵢ via median / P95 scaling"]
        S2c["Dynamic Masking Vector mᵏᵢ<br>(handles missing data w/o bias)"]
        S2c_tensor["🔍 Multi-Dimensional Tensor Decomposition<br>Treat wallet interactions as spatial matrix<br>over time vector → MIMO-style spatial<br>correlation clusters micro-transactions<br>into high-probability smurfing signatures — §6.1"]
        S2d["Node Risk Score r̃ᵢ<br>masked weighted average, clipped [0,1]"]
        S2a --> S2b --> S2c --> S2c_tensor --> S2d
    end

    subgraph S3["③ Target Discrimination — Clutter Rejection"]
        direction TB
        S3a["Subgraph Modularization<br>sᵢ = λᵣ r̃ᵢ + λₙCentralityᵢ + λₚPathRiskᵢ + λₐI[i=a]"]
        S3b["Top-20 High-Risk Subgraph G20<br>n = |V₂₀| ≤ 20 → quantum-ready size<br>Seed wallet a ∈ V₂₀ always enforced"]
        S3a --> S3b
    end

    subgraph S4["④ Core Processing Unit — Quantum Optimization"]
        direction TB
        S4a["QUBO Formulation w/ Fβ Cost Function (β=0.5)<br>C(x) = xᵀQx<br>CFAR-style: penalizes False Positives heavily — §4"]
        S4b["Ising Hamiltonian Mapping<br>H_C = Σᵢhᵢ Zᵢ + Σᵢ&lt;ⱼJᵢⱼZᵢZⱼ<br>Coupling Jᵢⱼ calibration: sensitivity check — §3"]
        S4c["QAOA Circuit Execution<br>γ*, β* = argmin ⟨Ψ|H|Ψ⟩<br>Depth p ∈ [p_min, p_max] — explicit bounds — §8<br>(Classical fallback: simulated annealing)"]
        S4d["Binary Output String<br>[1,0,1,1,0...] → flagged wallets<br>Quantum Evidence Score ζₐQ = (b*ᵢ + q̂Q) / 2 per wallet"]
        S4a --> S4b --> S4c --> S4d
    end

    subgraph S5_KILL["⑤a KILL CHAIN — Autonomous Interception (CIWS-level)"]
        direction TB
        S5_thresh{"riskscore ≥ 0.85?<br>(CFAR threshold — Kill Chain trigger)"}
        S5_freeze["🔴 IMMEDIATE FREEZE<br>Smart-contract / API halt triggered<br>directly by QUBO Optimizer<br>Zero LLM latency — §6.2"]
        S5_thresh -->|"breach"| S5_freeze
    end

    subgraph S5_ANALYSIS["⑤b ANALYSIS CHAIN — Post-Engagement (Parallel, Non-Blocking)"]
        direction TB
        S5b["Multi-Agent Crew Activation<br>Flow Tracer · OSINT Analyst · Compliance Officer"]
        S5c["External Intelligence Fusion<br>OpenSanctions · CryptoScamDB · KYC — §5"]
        S5d["Combined Compliance Score Rₐ<br>Rₐ = clip( ωr r̃ₐ + ωq ζₐQ + ωE Eₐ + ωS Sₐ + ωC Cₐ + ωO Oₐ, 0, 1 )<br>All ω ≥ 0, Σω = 1 — calibrated from historical labelled cases — §8"]
        S5b --> S5c --> S5d
    end

    subgraph S6["⑥ Output — Auditable Verdict & SAR Report"]
        direction TB
        S6a{"Decision Rule<br>(Thresholds τM, τH — calibrated, not hard-coded — §8)"}
        S6b["FREEZE<br>R ≥ τH or confirmed Sanctions / PEP hit"]
        S6c["MONITOR<br>τM ≤ R &lt; τH"]
        S6d["CLEAR<br>R &lt; τM"]
        S6e["SHA-256 Hashed JSON Report<br>tamper-evident audit trail<br>SAR-ready output from Analysis Chain"]
        S6a --> S6b
        S6a --> S6c
        S6a --> S6d
        S6b --> S6e
        S6c --> S6e
        S6d --> S6e
    end

    S1 --> S2 --> S3 --> S4 --> S5_KILL
    S4 --> S5_ANALYSIS
    S5_freeze -->|"parallel"| S5_ANALYSIS
    S5_ANALYSIS --> S5d
    S5d --> S6

    classDef stage fill:#f9f9f9,stroke:#333,stroke-width:1px;
    classDef killchain fill:#ffe0e0,stroke:#c00,stroke-width:2px,font-weight:bold;
    classDef analysis fill:#e0eaff,stroke:#336,stroke-width:1px;
    classDef security fill:#e8f5e9,stroke:#2e7d32,stroke-width:1.5px;
    classDef quantum fill:#f3e5f5,stroke:#6a1b9a,stroke-width:1.5px;
    classDef newnode fill:#fffde7,stroke:#f57f17,stroke-width:2px,font-style:italic;

    class S1a,S1b,S1c stage;
    class S1b_orch security;
    class S1b_rpc newnode;
    class S2a,S2b,S2c,S2d stage;
    class S2c_tensor newnode;
    class S3a,S3b stage;
    class S4a,S4b,S4c,S4d quantum;
    class S5_thresh,S5_freeze killchain;
    class S5b,S5c,S5d analysis;
    class S6a,S6b,S6c,S6d,S6e stage;
