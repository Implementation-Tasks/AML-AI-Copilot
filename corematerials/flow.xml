        <mxCell id="E_A1_S1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeWidth=2;strokeColor=#888888;exitX=1;exitY=0.5;entryX=0;entryY=0.25;" edge="1" parent="1" source="Agent1" target="Step1">
          <mxGeometry relative="1" as="geometry" />
