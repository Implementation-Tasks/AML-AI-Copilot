        <!-- Title & Desc -->
        <mxCell id="P3_Title" value="&lt;b style=&quot;font-size: 18px; color: #5a2c7a;&quot;&gt;Phân hệ 3: Vòng Lượng tử - Quantum Computing Module (Qiskit)&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="130" y="670" width="600" height="30" as="geometry" />
        </mxCell>
        <mxCell id="P3_Desc" value="&lt;span style=&quot;font-size: 14px;&quot;&gt;Nơi giải quyết bài toán bùng nổ tổ hợp (Combinatorial Explosion) khi các mối quan hệ đồ thị tăng theo hàm mũ — điểm nghẽn chí mạng của máy tính cổ điển.&lt;/span&gt;" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;resizable=0;points=[];strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="130" y="705" width="940" height="30" as="geometry" />
        </mxCell>

        <!-- Pipeline Steps Phase 3 -->
        <mxCell id="Step3" value="&lt;b style=&quot;font-size:14px&quot;&gt;Quantum Mapping&lt;/b&gt;&lt;br/&gt;Nhúng ma trận dòng tiền&lt;br/&gt;vào không gian Hilbert.&lt;br/&gt;&lt;i&gt;Qiskit FeatureMap&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e5f5;strokeColor=#8e24aa;shadow=1;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="480" y="770" width="220" height="80" as="geometry" />
        </mxCell>
        
        <mxCell id="Step4" value="&lt;b style=&quot;font-size:14px&quot;&gt;Graph Execution&lt;/b&gt;&lt;br/&gt;Xử lý vướng víu đồ thị,&lt;br/&gt;trả điểm rủi ro.&lt;br/&gt;&lt;i&gt;QGNN / QAOA&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e5f5;strokeColor=#8e24aa;shadow=1;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="480" y="1000" width="220" height="80" as="geometry" />
        </mxCell>

        <!-- Edge Phase 2 to Phase 3 -->
        <mxCell id="E_P2_S3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeWidth=3;strokeColor=#333333;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="P2_Router" target="Step3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Detail Cards Phase 3 -->
        <mxCell id="QCard1" value="&lt;b style=&quot;color:#8e24aa&quot;&gt;Quantum State Embedding:&lt;/b&gt;&lt;br/&gt;Sử dụng mạch tính năng ZZFeatureMap trong Qiskit để ánh xạ ma trận giao dịch tài chính cổ điển vào không gian lượng tử cao chiều (Hilbert Space). Các qubit đóng vai trò đại diện cho các thực thể tài khoản." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#cccccc;shadow=1;align=left;verticalAlign=top;spacing=10;fontFamily=Helvetica;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="130" y="760" width="290" height="110" as="geometry" />
        </mxCell>
        
        <mxCell id="QCard2" value="&lt;b style=&quot;color:#8e24aa&quot;&gt;Quantum Entanglement Modeling:&lt;/b&gt;&lt;br/&gt;Các cổng tương tác lượng tử (như cổng CNOT) được áp dụng để thiết lập sự vướng víu lượng tử giữa các qubit. Trạng thái vướng víu này đại diện cho sự liên kết/đồng thuận ngầm về mặt hành vi dịch chuyển dòng tiền giữa các tài khoản vệ tinh, giúp nhìn thấu các cấu trúc rửa tiền ẩn tầng." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#cccccc;shadow=1;align=left;verticalAlign=top;spacing=10;fontFamily=Helvetica;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="760" y="880" width="310" height="130" as="geometry" />
        </mxCell>
        
        <mxCell id="QCard3" value="&lt;b style=&quot;color:#8e24aa&quot;&gt;Thuật toán cốt lõi:&lt;/b&gt;&lt;br/&gt;Sử dụng Quantum Graph Neural Networks (QGNN) hoặc QAOA (Quantum Approximate Optimization Algorithm) để phát hiện các chu kỳ đồ thị khép kín (nhận diện dòng tiền đi vòng để xóa dấu vết) và phân cụm mạng lưới tài khoản ma trong thời gian thực." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#cccccc;shadow=1;align=left;verticalAlign=top;spacing=10;fontFamily=Helvetica;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="760" y="1030" width="310" height="120" as="geometry" />
        </mxCell>

