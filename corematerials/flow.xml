        <mxCell id="P2_Router" value="&lt;b style=&quot;font-size:15px;color:#856404&quot;&gt;Phân hệ 2: Bộ định tuyến thông minh&lt;/b&gt;&lt;br/&gt;&lt;i&gt;(Dynamic Routing Interface)&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3cd;strokeColor=#ffe69c;shadow=1;arcSize=20;spacing=10;fontFamily=Helvetica;" vertex="1" parent="1">
