  <diagram name="Architecture Optimized" id="1">
    <mxGraphModel dx="1400" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        
        <!-- ==================== PHASE 1: CỔ ĐIỂN ==================== -->
        <!-- Background Container -->
        <mxCell id="P1_Bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f4f9fc;strokeColor=#a0c4df;shadow=1;arcSize=3" vertex="1" parent="1">
          <mxGeometry x="100" y="50" width="1000" height="430" as="geometry" />
        </mxCell>
        <!-- Title & Desc -->
        <mxCell id="P1_Title" value="&lt;b style=&quot;font-size: 18px; color: #02528a;&quot;&gt;Phân hệ 1: Vòng Cổ điển - Intelligent Agentic Orchestration&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="130" y="70" width="550" height="30" as="geometry" />
        </mxCell>
        <mxCell id="P1_Desc" value="&lt;span style=&quot;font-size: 14px;&quot;&gt;Tối đa tỷ lệ báo động giả (False Positives) đối với các hành vi giao dịch thông thường và khoanh vùng các cấu trúc dòng tiền có tổ chức.&lt;/span&gt;" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;resizable=0;points=[];strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="130" y="105" width="940" height="30" as="geometry" />
        </mxCell>

        <!-- Pipeline Steps Phase 1 -->
        <mxCell id="Step1" value="&lt;b style=&quot;font-size:14px&quot;&gt;Ingestion &amp;amp; Filter&lt;/b&gt;&lt;br/&gt;Thu thập luồng giao dịch&lt;br/&gt;&amp;amp; lọc thô rủi ro.&lt;br/&gt;&lt;i&gt;AutoGen / ML&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1f5fe;strokeColor=#0288d1;shadow=1;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="480" y="180" width="220" height="80" as="geometry" />
        </mxCell>
        
        <mxCell id="Step2" value="&lt;b style=&quot;font-size:14px&quot;&gt;Agentic Audit&lt;/b&gt;&lt;br/&gt;Suy luận cây (ToT)&lt;br/&gt;phân tích sâu hành vi.&lt;br/&gt;&lt;i&gt;LangGraph / ToT&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1f5fe;strokeColor=#0288d1;shadow=1;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="480" y="360" width="220" height="80" as="geometry" />
        </mxCell>

        <!-- Detail Cards Phase 1 -->
        <mxCell id="Agent1" value="&lt;b style=&quot;color:#0288d1&quot;&gt;Transaction Ingestion Agent:&lt;/b&gt;&lt;br/&gt;Tiếp nhận luồng dữ liệu thời gian thực, thực hiện chuẩn hóa cấu trúc dữ liệu giao dịch (Địa chỉ IP, Số tài khoản nguồn/đích, Vận tốc giao dịch, Thiết bị)." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#cccccc;shadow=1;align=left;verticalAlign=top;spacing=10;fontFamily=Helvetica;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="130" y="160" width="290" height="100" as="geometry" />
        </mxCell>
        
        <mxCell id="Agent2" value="&lt;b style=&quot;color:#0288d1&quot;&gt;Rule &amp;amp; ML Screening Agent:&lt;/b&gt;&lt;br/&gt;Chạy các thuật toán học máy truyền thống (XGBoost / Isolation Forest) để chấm điểm rủi ro cơ bản dựa trên các đặc trưng tĩnh." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#cccccc;shadow=1;align=left;verticalAlign=top;spacing=10;fontFamily=Helvetica;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="130" y="280" width="290" height="90" as="geometry" />
        </mxCell>
        
        <mxCell id="Agent3" value="&lt;b style=&quot;color:#0288d1&quot;&gt;Tree of Thought (ToT) Audit Agent:&lt;/b&gt;&lt;br/&gt;Đối với các tài khoản vượt ngưỡng rủi ro cơ bản, Agent này kích hoạt khung tư duy cây để đánh giá đa giả thuyết độc lập (Ví dụ: Đánh giá xác suất giữa hành vi tiêu dùng đột xuất mùa lễ hội vs. Hành vi bị hack tài khoản vs. Tài khoản &quot;Mule&quot; gom tiền bẩn)." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#cccccc;shadow=1;align=left;verticalAlign=top;spacing=10;fontFamily=Helvetica;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="760" y="325" width="310" height="130" as="geometry" />
        </mxCell>

