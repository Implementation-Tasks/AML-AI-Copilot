# ⚛ AML AI Copilot - Environment Configuration
# SEA Quantathon 2026 · QCFinOp Team
#
# INSTRUCTIONS:
# 1. Copy this file to .env: cp .env.example .env
# 2. Fill in your API keys below
# 3. Never commit .env to git (already in .gitignore)

# ═══════════════════════════════════════════════════════════════════════════
# BLOCKCHAIN DATA SOURCES
# ═══════════════════════════════════════════════════════════════════════════

# Etherscan API (FREE tier available)
# Get your key: https://etherscan.io/apis
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# Dune Analytics API (OPTIONAL - for advanced queries)
# Get your key: https://dune.com/settings/api
DUNE_API_KEY=your_dune_api_key_here

# ═══════════════════════════════════════════════════════════════════════════
# SANCTIONS & COMPLIANCE DATA
# ═══════════════════════════════════════════════════════════════════════════

# OpenSanctions API (FREE tier available)
# Get your key: https://www.opensanctions.org/docs/api/
OPENSANCTIONS_API_KEY=your_opensanctions_api_key_here

# ═══════════════════════════════════════════════════════════════════════════
# AI / LLM PROVIDERS
# ═══════════════════════════════════════════════════════════════════════════

# Anthropic Claude (REQUIRED for CrewAI agents)
# Get your key: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI (OPTIONAL - alternative to Claude)
# Get your key: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# LLM Provider Selection
# Options: "anthropic" | "openai"
LLM_PROVIDER=anthropic

# Model Selection
# Anthropic: claude-sonnet-4-5, claude-3-5-sonnet-20241022, claude-3-opus-20240229
# OpenAI: gpt-4-turbo, gpt-4, gpt-3.5-turbo
LLM_MODEL=claude-sonnet-4-5

# ═══════════════════════════════════════════════════════════════════════════
# QUANTUM BACKEND CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════

# Quapp.cloud API (OPTIONAL - for quantum hardware access)
# Get your key: https://quapp.cloud/
QUAPP_API_KEY=your_quapp_api_key_here

# Quantum Backend Selection
# Options: "qudora" | "quandela" | "classical"
# - qudora: Qamelion trapped-ion emulator
# - quandela: Perceval photonic simulator
# - classical: Simulated Annealing (no quantum hardware)
QUANTUM_BACKEND=classical

# Quantum Job Timeout (seconds)
QUANTUM_TIMEOUT_SECONDS=30

# Maximum graph size for QUBO optimization
QUBO_MAX_NODES=500

# ═══════════════════════════════════════════════════════════════════════════
# AGENT CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════

# Agent retry attempts on failure
AGENT_RETRY_ATTEMPTS=3

# Agent timeout (seconds)
AGENT_TIMEOUT_SECONDS=300

# ═══════════════════════════════════════════════════════════════════════════
# AML THRESHOLDS (Prof. Hans Architecture)
# ═══════════════════════════════════════════════════════════════════════════

# QUBO risk threshold (0.0 - 1.0)
# If quantum evidence ζQ >= this threshold → trigger agents
QUBO_RISK_THRESHOLD=0.85

# F-beta parameter (β < 1 → Precision > Recall)
F_BETA=0.5

# Compliance Score Thresholds (Parametric)
# τH: HIGH risk → FREEZE
COMPLIANCE_THRESHOLD_HIGH=0.75

# τM: MEDIUM risk → MONITOR
COMPLIANCE_THRESHOLD_MED=0.45

# Compliance Score Weights (must sum to 1.0)
OMEGA_R=0.30  # Classical risk r̃
OMEGA_Q=0.25  # Quantum evidence ζQ
OMEGA_E=0.20  # External sanctions
OMEGA_S=0.15  # Scam/structuring
OMEGA_C=0.07  # Mixer exposure
OMEGA_O=0.03  # Bridge obfuscation

# ═══════════════════════════════════════════════════════════════════════════
# HAMILTONIAN CALIBRATION (QAOA Depth)
# ═══════════════════════════════════════════════════════════════════════════

# QAOA depth parameter bounds
QAOA_P_MIN=1
QAOA_P_MAX=5
QAOA_P_DEFAULT=2

# NISQ noise model parameters
NISQ_GATE_ERROR_RATE=0.01
NISQ_READOUT_ERROR=0.02

# ═══════════════════════════════════════════════════════════════════════════
# LOGGING & OBSERVABILITY
# ═══════════════════════════════════════════════════════════════════════════

# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Enable trace logging for debugging
TRACE_ENABLED=false

# ═══════════════════════════════════════════════════════════════════════════
# DEMO MODE (For testing without API keys)
# ═══════════════════════════════════════════════════════════════════════════

# If true, uses synthetic data instead of real API calls
DEMO_MODE=false
