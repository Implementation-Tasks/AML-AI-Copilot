# AML AI Copilot — Environment Variables Template
# Copy this file to .env and fill in your actual keys
# NEVER commit .env to version control

# === Quantum Backend ===
QUANTUM_BACKEND=classical                    # qudora | quandela | classical
QUANTUM_TIMEOUT_SECONDS=30
QUBO_MAX_NODES=500

# === API Keys ===
ETHERSCAN_API_KEY=your_etherscan_key_here
DUNE_API_KEY=your_dune_analytics_key_here
OPENSANCTIONS_API_KEY=your_opensanctions_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here
QUAPP_API_KEY=your_quapp_cloud_key_here

# === LLM Settings ===
LLM_PROVIDER=anthropic                       # anthropic | openai
LLM_MODEL=claude-sonnet-4-5

# === AML Thresholds ===
QUBO_RISK_THRESHOLD=0.85
F_BETA=0.5                                   # β < 1 → Precision > Recall

# === Agent Settings ===
AGENT_RETRY_ATTEMPTS=3
AGENT_TIMEOUT_SECONDS=300
